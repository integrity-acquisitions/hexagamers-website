---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  currentPost: CollectionEntry<'posts'>;
}

const { currentPost } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const currentCategories = currentPost.data.categories ?? [];
const currentId = currentPost.id;

// Fetch all posts, exclude current, find same-category matches
const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const related = allPosts
  .filter(p => p.id !== currentId)
  .map(p => {
    const shared = (p.data.categories ?? []).filter(c => currentCategories.includes(c));
    return { post: p, score: shared.length };
  })
  .filter(({ score }) => score > 0)
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;
    return b.post.data.date.getTime() - a.post.data.date.getTime();
  })
  .slice(0, 3)
  .map(({ post }) => post);

if (related.length === 0) return;

const categoryLabel: Record<string, string> = {
  'reviews':          'Review',
  'how-to-play':      'How To Play',
  'favourites-lists': 'Best-Of List',
  'miscellaneous':    'Article',
  'memes':            'Fun',
  'games':            'Games',
};
---

{related.length > 0 && (
  <section class="related-posts">
    <div class="related-header">
      <p class="section-label">More to Read</p>
    </div>
    <div class="related-grid">
      {related.map(post => {
        const { title, date, categories, coverImage } = post.data;
        const mainCat = categories?.[0] ?? 'games';
        const catDisplay = categoryLabel[mainCat] ?? mainCat;
        const formattedDate = date.toLocaleDateString('en-US', {
          month: 'short', day: 'numeric', year: 'numeric'
        });
        return (
          <a href={`${base}/blog/${post.id}/`} class="related-card">
            <div class="related-img">
              {coverImage
                ? <img src={coverImage} alt={title} loading="lazy" />
                : <div class="related-placeholder" aria-hidden="true">
                    <svg viewBox="0 0 60 70" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M30 2L58 17V53L30 68L2 53V17L30 2Z" stroke="currentColor" stroke-width="1.5" stroke-opacity="0.3"/>
                    </svg>
                  </div>
              }
            </div>
            <div class="related-body">
              <div class="related-meta">
                <span class="cat-badge">{catDisplay}</span>
                <time datetime={date.toISOString()}>{formattedDate}</time>
              </div>
              <h3 class="related-title">{title}</h3>
              <span class="related-cta">
                Read more
                <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M1 7h12M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </section>
)}

<style>
.related-posts {
  margin-top: 4rem;
  padding-top: 2.5rem;
  border-top: 1px solid var(--border);
}

.related-header {
  margin-bottom: 1.5rem;
}

.related-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}

.related-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  cursor: pointer;
}
.related-card:hover {
  border-color: rgba(240,165,0,0.35);
  transform: translateY(-3px);
  box-shadow: 0 8px 28px rgba(0,0,0,0.35);
}

.related-img {
  aspect-ratio: 16/9;
  overflow: hidden;
  flex-shrink: 0;
}
.related-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}
.related-card:hover .related-img img { transform: scale(1.05); }

.related-placeholder {
  width: 100%;
  height: 100%;
  background: var(--bg-3);
  display: flex;
  align-items: center;
  justify-content: center;
}
.related-placeholder svg {
  width: 40px;
  color: var(--amber);
}

.related-body {
  padding: 1.1rem 1.25rem 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex: 1;
}

.related-meta {
  display: flex;
  align-items: center;
  gap: 0.6rem;
}
.related-meta time {
  font-size: 0.7rem;
  color: var(--text-3);
  letter-spacing: 0.04em;
}

.related-title {
  font-family: var(--font-display);
  font-size: 0.95rem;
  font-weight: 700;
  line-height: 1.3;
  color: var(--text);
  transition: color 0.15s;
  margin: 0;
}
.related-card:hover .related-title { color: var(--amber-light); }

.related-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.35em;
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--amber);
  letter-spacing: 0.05em;
  margin-top: auto;
  padding-top: 0.4rem;
  transition: gap 0.15s;
}
.related-card:hover .related-cta { gap: 0.55em; }

@media (max-width: 768px) {
  .related-grid { grid-template-columns: 1fr; }
}
@media (min-width: 480px) and (max-width: 768px) {
  .related-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>
