---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  pagefindIgnore?: boolean;
  ogType?: string;
  publishedTime?: string;
  noindex?: boolean;
}

const {
  title = 'Hexagamers — Board Game Reviews & Guides',
  description = 'In-depth board game reviews, how-to-play guides, and curated lists for tabletop enthusiasts.',
  image = '/og-default.jpg',
  canonicalUrl,
  pagefindIgnore = false,
  ogType = 'website',
  publishedTime,
  noindex = false,
} = Astro.props;

const siteUrl = 'https://hexagamers.com';
const fullTitle = title.includes('Hexagamers') ? title : `${title} | Hexagamers`;
const canonical = canonicalUrl ?? siteUrl + Astro.url.pathname;
const ogImage = image.startsWith('http') ? image : siteUrl + image;
const ga4Id = import.meta.env.PUBLIC_GA4_ID;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, follow" />}

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Hexagamers" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon-logo.png" />
  <link rel="apple-touch-icon" href="/favicon-logo.png" />

  <!-- Sitemap -->
  <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

  <!-- WebSite schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Hexagamers",
    "url": siteUrl,
    "description": "In-depth board game reviews, how-to-play guides, and curated lists for tabletop enthusiasts.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": `${siteUrl}/search/?q={search_term_string}` },
      "query-input": "required name=search_term_string"
    }
  })} />

  <!-- Preconnect for fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Page-specific head additions (e.g. post schema) -->
  <slot name="head" />

  <!-- Google Analytics 4 -->
  {ga4Id && ga4Id !== 'G-XXXXXXXXXX' && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
      <script define:vars={{ ga4Id }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', ga4Id);
      </script>
    </>
  )}
</head>
<body data-pagefind-ignore={pagefindIgnore ? "all" : undefined}>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
</body>
</html>
