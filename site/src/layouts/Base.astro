---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  pagefindIgnore?: boolean;
  ogType?: string;
  publishedTime?: string;
  noindex?: boolean;
}

const {
  title = 'Hexagamers — Board Game Reviews & Guides',
  description = 'In-depth board game reviews, how-to-play guides, and curated lists for tabletop enthusiasts.',
  image = '/og-default.jpg',
  canonicalUrl,
  pagefindIgnore = false,
  ogType = 'website',
  publishedTime,
  noindex = false,
} = Astro.props;

const siteUrl = 'https://hexagamers.com';
const fullTitle = title.includes('Hexagamers') ? title : `${title} | Hexagamers`;
const canonical = canonicalUrl ?? siteUrl + Astro.url.pathname;
const ogImage = image.startsWith('http') ? image : siteUrl + image;
const ga4Id = import.meta.env.PUBLIC_GA4_ID;
---
<!doctype html>
<html lang="en" id="top">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, follow" />}

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Hexagamers" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon-logo.png" />
  <link rel="apple-touch-icon" href="/favicon-logo.png" />

  <!-- Sitemap -->
  <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

  <!-- WebSite schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Hexagamers",
    "url": siteUrl,
    "description": "In-depth board game reviews, how-to-play guides, and curated lists for tabletop enthusiasts.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": `${siteUrl}/search/?q={search_term_string}` },
      "query-input": "required name=search_term_string"
    }
  })} />

  <!-- Organization schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Hexagamers",
    "url": siteUrl,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/favicon-logo.png`
    },
    "description": "In-depth board game reviews, how-to-play guides, and curated lists to help you find your next great tabletop game.",
    "sameAs": []
  })} />

  <!-- Preconnect for fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Page-specific head additions (e.g. post schema) -->
  <slot name="head" />

  <!-- Google Analytics 4 -->
  {ga4Id && ga4Id !== 'G-XXXXXXXXXX' && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
      <script define:vars={{ ga4Id }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', ga4Id);
      </script>
    </>
  )}
</head>
<body data-pagefind-ignore={pagefindIgnore ? "all" : undefined}>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
  <a href="#top" id="back-to-top" aria-label="Back to top">
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
      <path d="M9 14V4M4 9l5-5 5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    Back to top
  </a>
</body>
</html>

<style is:global>
#back-to-top {
  position: fixed;
  bottom: 2rem;
  right: 2rem;
  display: inline-flex;
  align-items: center;
  gap: 0.4em;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  color: var(--text-2);
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 2rem;
  padding: 0.5rem 1rem;
  text-decoration: none;
  opacity: 0;
  pointer-events: none;
  transform: translateY(8px);
  transition: opacity 0.25s, transform 0.25s, color 0.15s, border-color 0.15s;
  z-index: 50;
  box-shadow: 0 4px 16px rgba(0,0,0,0.3);
}
#back-to-top.visible {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}
#back-to-top:hover {
  color: var(--amber);
  border-color: rgba(240,165,0,0.35);
}
@media (max-width: 640px) {
  #back-to-top { bottom: 1.25rem; right: 1.25rem; }
}
</style>

<script is:inline>
(function() {
  var btn = document.getElementById('back-to-top');
  if (!btn) return;
  window.addEventListener('scroll', function() {
    if (window.scrollY > 400) {
      btn.classList.add('visible');
    } else {
      btn.classList.remove('visible');
    }
  }, { passive: true });
})();
</script>
