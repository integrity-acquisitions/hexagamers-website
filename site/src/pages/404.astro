---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="Page Not Found" description="This page doesn't exist.">
  <div class="not-found">
    <div class="container not-found-inner">
      <div class="hex-404" aria-hidden="true">
        <svg viewBox="0 0 120 138" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M60 2L118 35V105L60 138L2 105V35L60 2Z" stroke="currentColor" stroke-width="2" stroke-opacity="0.3"/>
          <path d="M60 20L102 44V92L60 116L18 92V44L60 20Z" stroke="currentColor" stroke-width="1.5" stroke-opacity="0.15"/>
          <text x="60" y="82" text-anchor="middle" font-family="Georgia,serif" font-weight="900" font-size="44" fill="currentColor" fill-opacity="0.4">404</text>
        </svg>
      </div>
      <h1>Lost in the Game Box</h1>
      <p>This page got shuffled out of the deck. Let's get you back on the board.</p>
      <div class="not-found-actions">
        <a href={`${base}/`} class="btn btn-primary">Go Home</a>
        <a href={`${base}/blog/`} class="btn btn-outline">Browse Posts</a>
      </div>
    </div>
  </div>
</Base>

<style>
.not-found { padding: 6rem 0; }
.not-found-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 1.5rem;
}
.hex-404 {
  width: 120px;
  color: var(--amber);
  margin-bottom: 1rem;
}
.hex-404 svg { width: 100%; height: 100%; }
.not-found h1 { font-size: clamp(1.8rem, 4vw, 3rem); }
.not-found p { color: var(--text-2); max-width: 380px; }
.not-found-actions { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; margin-top: 0.5rem; }
</style>
